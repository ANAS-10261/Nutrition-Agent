# ─────────────────────────────────────────────────────
#  IBM Watsonx.ai  ·  Nutrition Agent  ·  .env.example
#  Rename this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────

# IBM Cloud API Key (required)
# Get it from: https://cloud.ibm.com/iam/apikeys
IBM_API_KEY=your_ibm_cloud_api_key_here

# IBM Watsonx.ai Project ID (required)
# Get it from: https://dataplatform.cloud.ibm.com → Your Project → Manage → General
IBM_PROJECT_ID=your_watsonx_project_id_here

# ── Endpoint URL ──────────────────────────────────────────────────────────────
# Standard IBM Cloud SaaS (most users):
#   IBM_URL=https://us-south.ml.cloud.ibm.com   (US South)
#   IBM_URL=https://eu-de.ml.cloud.ibm.com      (EU Frankfurt)
#   IBM_URL=https://jp-tok.ml.cloud.ibm.com     (Tokyo)
#
# Cloud Pak for Data / IBM watsonx.ai SaaS Asia-Pacific:
#   IBM_URL=https://au-syd.dai.cloud.ibm.com
#   (CPD endpoints also require IBM_USERNAME and IBM_VERSION below)
IBM_URL=https://us-south.ml.cloud.ibm.com

# ── Cloud Pak for Data (CPD) only ─────────────────────────────────────────────
# Required ONLY if your IBM_URL is a CPD endpoint (e.g. .dai.cloud.ibm.com).
# Leave blank / commented out for standard IBM Cloud SaaS.
#
# IBM_USERNAME=your_ibm_id_email@example.com
# IBM_VERSION=5.1   # CPD platform version: 5.0 | 5.1 | 5.2 | 5.3 | 5.4

# Flask configuration
FLASK_SECRET_KEY=change_this_to_a_long_random_string_in_production
FLASK_DEBUG=false
PORT=5000
